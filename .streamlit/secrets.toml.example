# Citadel Archival Search — Streamlit Secrets Template
# ======================================================
# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to version control — it is in .gitignore.
#
# On Streamlit Community Cloud:
#   Go to App Settings → Secrets → paste these key=value pairs directly.

# ── Groq (LLM inference) ───────────────────────────────────────────────────
# Free tier: https://console.groq.com
GROQ_API_KEY = "gsk_your_groq_api_key_here"

# ── Qdrant Cloud (vector database) ────────────────────────────────────────
# Free 1GB cluster: https://cloud.qdrant.io
QDRANT_URL = "https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.us-east4-0.gcp.cloud.qdrant.io:6333"
QDRANT_API_KEY = "your_qdrant_api_key_here"

# ── Neo4j Aura Free (graph database) ──────────────────────────────────────
# Free instance: https://neo4j.com/cloud/platform/aura-graph-database/
NEO4J_URI = "neo4j+s://xxxxxxxx.databases.neo4j.io"
NEO4J_USERNAME = "neo4j"
NEO4J_PASSWORD = "your_neo4j_aura_password_here"

# ── LangSmith (optional — observability / tracing) ────────────────────────
# Free tier: https://smith.langchain.com
# Remove or leave blank to disable tracing
# LANGCHAIN_TRACING_V2 = "true"
# LANGCHAIN_API_KEY = "ls__your_langsmith_key_here"
